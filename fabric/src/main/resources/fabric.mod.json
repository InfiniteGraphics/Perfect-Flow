{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author_primary}",
        "${mod_author_secondary}"
    ],
    "icon": "icon.png",
    "contact": {
        "homepage": "${mod_homepage}",
        "sources": "${mod_sources}",
        "issues": "${mod_issues}"
    },
    "license": "${license}",
    "environment": "client",
    "entrypoints": {
        "client": [
          "com.perfectflow.fabric.PerfectFlowFabric"
        ],
        "modmenu": [
          "com.perfectflow.fabric.config.PerfectFlowModMenu"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}",
        "modmenu": ">=${modmenu_version}",
        "cloth-config": ">=${cloth_config_version}"
    },
    "suggests": {
        "iris": "*"
    }
}
  
